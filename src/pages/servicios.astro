---

<Layout title="Servicios - Estudio Novara" description="Conoce todos los servicios de asesoramiento contable, fiscal, laboral y de gestión que ofrece Estudio Novara.">
	<!-- Hero -->
	<div class="bg-gradient-to-br from-white via-gray-50 to-gray-100 pt-24 pb-16">
		<div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto">
				<h1 class="text-6xl font-montserrat font-bold text-primary-negro mb-6">
					Nuestros Servicios
				</h1>
				<p class="text-xl text-gray-600 font-light">
					Soluciones especializadas diseñadas para impulsar tu negocio
				</p>
			</div>
		</div>
	</div>

	<!-- Pantallazo de Servicios -->
	<div class="bg-white py-12">
		<div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{services.map((service) => (
					<div
						class="rounded-2xl border border-gray-200 bg-gray-50 p-6 shadow-sm hover:shadow-md transition-shadow cursor-pointer"
						data-service-card
						data-target={`service-${service.id}`}
						role="button"
						tabindex="0"
						aria-label={`Ir a ${service.title}`}
					>
						<div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-r ${service.bgColor} text-white mb-4`}>
							<i class={`fas ${service.icon} text-lg`}></i>
						</div>
						<h3 class="text-lg font-montserrat font-bold text-primary-negro mb-2">
							<a href={`#service-${service.id}`} class="hover:text-primary-naranja transition-colors">
								{service.title}
							</a>
						</h3>
						<p class="text-sm text-gray-600 mb-4">
							{service.description}
						</p>
						<div class="flex flex-wrap gap-2">
							{service.subcategories.map((sub) => (
								<a
									href={`#content-${service.id}-${sub.id}`}
									class="text-xs font-semibold text-primary-azul bg-white border border-gray-200 px-2.5 py-1 rounded-full hover:border-primary-azul hover:text-primary-naranja transition-colors"
								>
									{sub.name}
								</a>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
	</div>

	<!-- Services -->
	<div class="bg-white py-20">
		<div class="max-w-screen-2xl mx-auto px-6 lg:px-8 space-y-20">
			{services.map((service, serviceIdx) => (
				<div id={`service-${service.id}`} class="space-y-8 scroll-mt-28">
					<!-- Service Header -->
					<div class={`bg-gradient-to-r ${service.bgColor} rounded-2xl px-6 lg:px-12 py-8 lg:py-12 text-white shadow-lg`}>
						<div class="flex items-start gap-4 lg:gap-5">
							<div class="w-14 h-14 lg:w-20 lg:h-20 bg-white bg-opacity-15 rounded-xl flex items-center justify-center flex-shrink-0">
								<i class={`fas ${service.icon} text-2xl lg:text-4xl`}></i>
							</div>
							<div>
								<h2 class="text-2xl lg:text-4xl font-montserrat font-bold mb-2 lg:mb-3">{service.title}</h2>
								<p class="text-base lg:text-lg text-white text-opacity-90">{service.description}</p>
							</div>
						</div>
					</div>

					<!-- Tabs y Contenido -->
					<div class="bg-gray-50 rounded-2xl overflow-hidden border border-gray-200">
						<div class="bg-white border-b-2 border-gray-100">
							<div class="flex flex-wrap max-w-full px-6 lg:px-10 overflow-x-auto">
								{service.subcategories.map((sub, subIdx) => (
									<button
										class={`tab-btn-${service.id} py-5 px-6 text-base font-semibold transition-all duration-300 border-b-4 whitespace-nowrap relative group ${
											subIdx === 0 
												? 'text-primary-naranja border-b-primary-naranja' 
												: 'text-gray-600 border-b-transparent hover:text-primary-naranja'
										}`}
										data-service={service.id}
										data-tab={sub.id}
									>
										{sub.name}
									</button>
								))}
							</div>
						</div>

						<!-- Tab Content -->
						<div class="bg-white">
							{service.subcategories.map((sub, subIdx) => (
								<div
									id={`content-${service.id}-${sub.id}`}
									class={`${subIdx !== 0 ? 'hidden' : ''} transition-opacity duration-300 scroll-mt-28`}
									data-service={`${service.id}`}
								>
									<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 p-8 lg:p-12">
										<!-- Descripción -->
										<div class="space-y-6">
											<ul class="space-y-4">
												{sub.description.map((item) => (
													<li class="flex gap-4 text-gray-700 leading-relaxed text-base">
														<span class="text-primary-naranja font-bold text-xl mt-0.5 flex-shrink-0">✓</span>
														<span>{item}</span>
													</li>
												))}
											</ul>
											<a 
												href="/contacto"
												class="inline-block mt-8 bg-primary-naranja text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-azul transition-all transform hover:scale-105"
											>
												Solicitar información
											</a>
										</div>

										<!-- Video -->
										<div class="flex flex-col justify-center">
											<div class="aspect-video bg-gray-900 rounded-xl overflow-hidden shadow-xl">
												<iframe 
													width="100%" 
													height="100%" 
													src={`https://www.youtube-nocookie.com/embed/${sub.videoId}?rel=0&modestbranding=1`}
													title={sub.name}
													frameborder="0" 
													allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
													allowfullscreen
													class="w-full h-full">
												</iframe>
											</div>
										</div>
									</div>
								</div>
							))}
						</div>
					</div>
				</div>
			))}
		</div>
	</div>

	<!-- CTA Final -->
	<div class="bg-gradient-to-r from-primary-naranja to-orange-600 py-16">
		<div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
			<h3 class="text-4xl font-montserrat font-bold text-white mb-4">
				Iniciemos tu transformación digital
			</h3>
			<p class="text-lg text-orange-50 mb-8">
				Elige el servicio que necesitas y contáctanos para una consulta personalizada en /servicios por #SolucionesATuMedida
			</p>
			<a 
				href="/contacto" 
				class="inline-block bg-white text-primary-naranja px-10 py-4 rounded-lg font-montserrat font-bold hover:bg-gray-100 transition-all shadow-lg hover:shadow-xl text-lg"
			>
				Contactar ahora
			</a>
		</div>
	</div>
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const tabButtons = document.querySelectorAll('button[data-service][data-tab]');
		const serviceCards = document.querySelectorAll('[data-service-card]');
		const activeClasses = ['text-primary-naranja', 'border-b-primary-naranja'];
		const inactiveClasses = ['text-gray-600', 'border-b-transparent'];

		const scrollToTarget = (targetId) => {
			if (!targetId) return;
			const target = document.getElementById(targetId);
			if (target) {
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		};

		const activateTab = (serviceId, tabId) => {
			if (!serviceId || !tabId) return;

			// Hide all content for this service
			document.querySelectorAll(`[data-service="${serviceId}"]`).forEach(el => {
				if (el.id) el.classList.add('hidden');
			});
			
			// Show selected content
			const contentElement = document.getElementById(`content-${serviceId}-${tabId}`);
			if (contentElement) {
				contentElement.classList.remove('hidden');
			}
			
			// Remove active styles from all buttons in this service
			document.querySelectorAll(`button[data-service="${serviceId}"]`).forEach(btn => {
				btn.classList.remove(...activeClasses);
				btn.classList.add(...inactiveClasses);
			});
			
			// Add active styles to clicked button
			const activeButton = document.querySelector(`button[data-service="${serviceId}"][data-tab="${tabId}"]`);
			if (activeButton) {
				activeButton.classList.remove(...inactiveClasses);
				activeButton.classList.add(...activeClasses);
			}
		};

		const activateFromHash = () => {
			const hash = window.location.hash || '';
			if (!hash.startsWith('#content-')) return;

			const parts = hash.replace('#content-', '').split('-');
			if (parts.length < 2) return;

			const serviceId = parts[0];
			const tabId = parts.slice(1).join('-');
			activateTab(serviceId, tabId);

			const headerTarget = document.getElementById(`service-${serviceId}`);
			if (headerTarget) {
				headerTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		};

			serviceCards.forEach(card => {
				card.addEventListener('click', (event) => {
					if (event.target.closest('a')) return;
					const targetId = card.getAttribute('data-target');
					scrollToTarget(targetId);
				});
				card.addEventListener('keydown', (event) => {
					if (event.key !== 'Enter' && event.key !== ' ') return;
					event.preventDefault();
					const targetId = card.getAttribute('data-target');
					scrollToTarget(targetId);
				});
			});
		
		tabButtons.forEach(button => {
			button.addEventListener('click', () => {
				const serviceId = button.getAttribute('data-service');
				const tabId = button.getAttribute('data-tab');
				activateTab(serviceId, tabId);
			});
		});

		activateFromHash();
		window.addEventListener('hashchange', activateFromHash);
	});
</script>

<style>
	iframe {
		-webkit-user-select: none;
		user-select: none;
	}
</style>
