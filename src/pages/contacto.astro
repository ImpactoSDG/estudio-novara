---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto - Estudio Novara" description="Ponte en contacto con Estudio Novara. Ubicación, teléfono, email y horarios de atención.">
	<div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<!-- Encabezado -->
		<section class="text-center mb-16">
			<h1 class="text-5xl font-montserrat font-bold text-primary-negro mb-4">
				Contactanos
			</h1>
			<p class="text-xl text-gray-600">
				Coordiná una reunión sin compromiso<br />
				Tu consulta no nos molesta! Podés contactarnos por las redes también!
			</p>
		</section>

		<!-- Grid de contacto -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16">
			<!-- Información de contacto -->
			<div>
				<!-- Email -->
				<div class="mb-8 pb-8 border-b border-gray-300">
					<h3 class="text-xl font-semibold text-primary-negro mb-2">
						📧 Email
					</h3>
					<div class="mt-4">
						<a href="mailto:administracion@estudionovara.com" class="btn-primary inline-flex items-center gap-2">
							<i class="fa-regular fa-envelope"></i>
							Enviar mail a administracion@estudionovara.com
						</a>
					</div>
				</div>

				<!-- Horarios -->
				<div class="mb-8">
					<h3 class="text-xl font-semibold text-primary-negro mb-4">
						🕐 Horarios
					</h3>
					<div class="space-y-2 text-gray-700">
						<div class="flex justify-between">
							<span class="font-medium">Lunes a Viernes:</span>
							<span>7:30 - 15:30 hs</span>
						</div>
						<div class="flex justify-between">
							<span class="font-medium">Sábados y Domingos:</span>
							<span>Cerrado</span>
						</div>
					</div>
				</div>

				<!-- CTA WhatsApp -->
				<div class="mt-12 p-6 bg-green-50 rounded-lg border-l-4 border-green-500">
					<p class="text-gray-700 mb-4">
						¿Prefieres hablar por WhatsApp? Estamos disponibles para responder tus consultas.
					</p>
					<a href="https://api.whatsapp.com/send/?phone=5493564651485&text&type=phone_number&app_absent=0" target="_blank" rel="noopener noreferrer" class="btn-primary inline-block bg-green-500 hover:bg-green-600">
						Contactar por WhatsApp
					</a>
				</div>
			</div>

			<!-- Mapa -->
			<div>
				<h3 class="text-xl font-semibold text-primary-negro mb-4">
					📍 Dirección
				</h3>
				<p class="text-gray-700 text-lg mb-4">
					General Paz 304, San Francisco, Córdoba
				</p>
				<div class="rounded-lg overflow-hidden shadow-lg mb-4">
					<iframe
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3390.2365071838544!2d-62.21869!3d-31.425012!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b5a8c6b1e5e5e5%3A0x1234567890abcdef!2sGeneral%20Paz%20304%2C%20San%20Francisco%2C%20C%C3%B3rdoba!5e0!3m2!1ses!2sar!4v1640000000000"
						width="100%"
						height="400"
						style="border:0;"
						allowfullscreen=""
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						class="w-full"
					></iframe>
				</div>
				<p class="text-gray-600 text-sm">
					Haz clic en el mapa para abrir en Google Maps
				</p>
			</div>
		</div>

	</div>
</Layout>
