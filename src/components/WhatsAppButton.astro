---
// WhatsApp floating button component
// Automatically detects device and routes to appropriate WhatsApp URL
const phoneNumber = "5493564651485";
const whatsappWebUrl = `https://web.whatsapp.com/send/?phone=${phoneNumber}&text&type=phone_number&app_absent=0`;
const whatsappMobileUrl = `https://api.whatsapp.com/send/?phone=${phoneNumber}&text&type=phone_number&app_absent=0`;
---

<div class="fixed bottom-6 right-6 z-40">
  <!-- Desktop: WhatsApp Web -->
  <a
    href={whatsappWebUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="hidden md:flex relative items-center justify-center w-16 h-16 group"
    aria-label="Contactar por WhatsApp"
  >
    <span class="whatsapp-ring absolute inset-0 rounded-full"></span>
    <span class="absolute inset-0 rounded-full bg-green-500/40 blur-lg opacity-60 group-hover:opacity-80 transition-opacity duration-300"></span>
    <span class="relative flex items-center justify-center w-16 h-16 rounded-full bg-green-500 shadow-[0_10px_25px_rgba(34,197,94,0.45)] group-hover:scale-105 transition-transform duration-200">
      <i class="fa-brands fa-whatsapp text-white text-3xl"></i>
    </span>

    <!-- Tooltip -->
    <div class="absolute bottom-full mb-2 bg-gray-800 text-white text-sm font-medium px-3 py-2 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
      Contáctanos por WhatsApp
    </div>
  </a>

  <!-- Mobile: WhatsApp -->
  <a
    href={whatsappMobileUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="md:hidden relative flex items-center justify-center w-16 h-16 group"
    aria-label="Contactar por WhatsApp"
  >
    <span class="whatsapp-ring absolute inset-0 rounded-full"></span>
    <span class="absolute inset-0 rounded-full bg-green-500/40 blur-lg opacity-60 group-hover:opacity-80 transition-opacity duration-300"></span>
    <span class="relative flex items-center justify-center w-16 h-16 rounded-full bg-green-500 shadow-[0_10px_25px_rgba(34,197,94,0.45)] group-hover:scale-105 transition-transform duration-200">
      <i class="fa-brands fa-whatsapp text-white text-3xl"></i>
    </span>

    <!-- Mobile Tooltip -->
    <div class="absolute bottom-full mb-2 bg-gray-800 text-white text-sm font-medium px-3 py-2 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
      Contáctanos por WhatsApp
    </div>
  </a>
</div>

<style>
  @keyframes floaty {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  @keyframes ring {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    70% {
      transform: scale(1.8);
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  .whatsapp-ring {
    background: rgba(34, 197, 94, 0.35);
    animation: ring 2.4s ease-out infinite;
  }

  .whatsapp-ring + span + span {
    animation: floaty 3.4s ease-in-out infinite;
  }
</style>
